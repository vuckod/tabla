# VZOREC za .kamal/secrets — kopiraj v .kamal/secrets in izpolni prave vrednosti.
# .kamal/secrets je v .gitignore (NIKOLI v git, ker vsebuje gesla).
#
# Kamal bere te spremenljivke ob deployu. Vrednosti naj pridejo iz ENV ali
# password managerja, NE kot golo besedilo, kjer se da.

# Master key (iz config/master.key — datoteka je v .gitignore)
RAILS_MASTER_KEY=$(cat config/master.key)

# Gitea registry geslo (osebni dostopni žeton, ne pravo geslo)
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# PostgreSQL (accessory tabla-db). DATABASE_URL kaže na ime kontejnerja + NOTRANJI port 5432.
POSTGRES_PASSWORD=$TABLA_POSTGRES_PASSWORD
DATABASE_URL=postgres://tabla_user:$TABLA_POSTGRES_PASSWORD@tabla-db:5432/tabla_production

# Meilisearch (accessory tabla-meilisearch; MEILI_MASTER_KEY in MEILISEARCH_MASTER_KEY = ista vrednost)
MEILI_MASTER_KEY=$TABLA_MEILI_MASTER_KEY
MEILISEARCH_MASTER_KEY=$TABLA_MEILI_MASTER_KEY

# Prisotnost API žeton (Bearer; isti kot v razvoju ali produkcijski)
PRISOTNOST_API_TOKEN=$TABLA_PRISOTNOST_API_TOKEN

# SMTP poverilnice (mail.arnes.si). Če strežnik ne zahteva avtentikacije, pusti prazno.
SMTP_USERNAME=$TABLA_SMTP_USERNAME
SMTP_PASSWORD=$TABLA_SMTP_PASSWORD
