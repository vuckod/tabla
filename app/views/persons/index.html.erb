<% content_for :title, t("views.titles.persons") %>

<div class="mb-8 print:mb-4">
  <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 print:text-xl print:text-black">
    <%= t("views.persons.title") %>
  </h1>
</div>

<%= render "locations_section", locations: @locations %>

<%= turbo_frame_tag "persons_list" do %>
  <div class="mt-10">
    <h2 class="text-xl font-semibold text-slate-800 dark:text-slate-200 mb-4">
      <%= t("views.persons.employees") %>
    </h2>

    <%= form_with url: persons_path, method: :get,
        data: { controller: "auto-submit", turbo_frame: "persons_list" },
        class: "mb-6 flex flex-col sm:flex-row gap-3 print:hidden" do |f| %>
      <div class="flex-1">
        <label for="q" class="sr-only"><%= t("views.shared.search_placeholder") %></label>
        <%= f.search_field :q, value: params[:q],
            placeholder: t("views.persons.search_placeholder"),
            class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800
                    dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500",
            data: { action: "input->auto-submit#submit" } %>
      </div>

      <div class="sm:w-64">
        <label for="location_id" class="sr-only"><%= t("views.persons.filter_location") %></label>
        <%= f.collection_select :location_id,
            @locations, :id, :name,
            { selected: params[:location_id], include_blank: t("views.persons.all_locations") },
            class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800
                    dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500",
            data: { action: "change->auto-submit#submit" } %>
      </div>
    <% end %>

    <% if @persons.empty? %>
      <%= render "shared/empty_state",
          icon: :users,
          title: t("views.persons.empty_title"),
          message: t("views.persons.empty_message"),
          action: (if params[:q].present? || params[:location_id].present?
            link_to t("views.persons.reset_filters"), persons_path,
                class: "text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:underline"
          end) %>
    <% else %>
      <%# Desktop tabela %>
      <div class="hidden md:block print:block overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700 print:border-0 print:rounded-none">
        <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
          <thead class="bg-slate-50 dark:bg-slate-800">
            <tr>
              <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                <%= Person.human_attribute_name(:last_name) %>
              </th>
              <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                <%= Person.human_attribute_name(:position_title) %>
              </th>
              <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                <%= Person.human_attribute_name(:location) %>
              </th>
              <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                <%= t("views.persons.phone_numbers") %>
              </th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-slate-900 divide-y divide-slate-200 dark:divide-slate-700">
            <% @persons.each do |person| %>
              <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
                <td class="px-4 py-3 whitespace-nowrap">
                  <%= link_to person.full_name, person_path(person),
                      class: "font-medium text-indigo-600 dark:text-indigo-400 hover:underline" %>
                  <% if person.email.present? %>
                    <div class="text-sm text-slate-500 dark:text-slate-400">
                      <%= mail_to person.email, person.email,
                          class: "hover:text-indigo-600 dark:hover:text-indigo-400" %>
                    </div>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300">
                  <%= person.position_title %>
                </td>
                <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300">
                  <%= person.location&.name %>
                </td>
                <td class="px-4 py-3">
                  <%= render_phone_numbers_list(person.phone_numbers) %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <%# Mobilne kartice %>
      <div class="md:hidden print:hidden space-y-4">
        <% @persons.each do |person| %>
          <article class="bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-4 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">
              <%= link_to person.full_name, person_path(person),
                  class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
            </h3>
            <% if person.position_title.present? %>
              <p class="text-sm text-slate-600 dark:text-slate-400 mt-1"><%= person.position_title %></p>
            <% end %>
            <% if person.location.present? %>
              <p class="text-sm text-slate-500 dark:text-slate-400 mt-1"><%= person.location.name %></p>
            <% end %>
            <% if person.email.present? %>
              <p class="text-sm mt-2">
                <%= mail_to person.email, person.email,
                    class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
              </p>
            <% end %>
            <div class="mt-3 pt-3 border-t border-slate-100 dark:border-slate-700">
              <%= render_phone_numbers_list(person.phone_numbers) %>
            </div>
          </article>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
