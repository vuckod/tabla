<% content_for :title, t("views.admin.announcements.title") %>

<%= render "admin/nav" %>

<%= render "admin/shared/index_header",
    title: t("views.admin.announcements.title"),
    new_label: t("views.admin.announcements.new"),
    new_path: new_admin_announcement_path %>

<% if @announcements.any? %>
  <div class="overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700">
    <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
      <thead class="bg-slate-50 dark:bg-slate-800">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Announcement.human_attribute_name(:title) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Announcement.human_attribute_name(:unit) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Announcement.human_attribute_name(:published_at) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Announcement.human_attribute_name(:expires_at) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= t("views.admin.announcements.status") %></th>
          <th class="px-4 py-3 text-right text-xs font-medium text-slate-500 dark:text-slate-400 uppercase print:hidden"><%= t("views.shared.actions") %></th>
        </tr>
      </thead>
      <tbody class="bg-white dark:bg-slate-900 divide-y divide-slate-200 dark:divide-slate-700">
        <% @announcements.each do |announcement| %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
            <td class="px-4 py-3 text-sm font-medium text-slate-900 dark:text-slate-100"><%= announcement.title %></td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300"><%= announcement_unit_label(announcement.unit) %></td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300"><%= l(announcement.published_at, format: :short) %></td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300">
              <%= announcement.expires_at ? l(announcement.expires_at, format: :short) : "—" %>
            </td>
            <td class="px-4 py-3 text-sm"><%= announcement_status_badge(announcement) %></td>
            <td class="px-4 py-3 text-right text-sm space-x-3 print:hidden">
              <%= link_to t("views.shared.edit"), edit_admin_announcement_path(announcement),
                  class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
              <% if policy(announcement).destroy? %>
                <%= button_to t("views.shared.delete"), admin_announcement_path(announcement),
                    method: :delete,
                    form: { data: { turbo_confirm: t("views.shared.confirm_delete") } },
                    class: "inline text-red-600 dark:text-red-400 hover:underline cursor-pointer" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "admin/shared/empty_state", message: t("views.admin.shared.empty_list") %>
<% end %>
