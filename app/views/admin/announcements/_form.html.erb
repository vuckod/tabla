<%= form_with model: [:admin, announcement], class: "space-y-6 max-w-2xl" do |f| %>
  <% if announcement.errors.any? %>
    <div class="p-4 rounded-lg bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300 border border-red-200 dark:border-red-800">
      <ul class="list-disc list-inside text-sm">
        <% announcement.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.text_field :title, required: true,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :body, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.text_area :body, rows: 5,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <fieldset>
    <legend class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
      <%= Announcement.human_attribute_name(:unit) %>
    </legend>
    <div class="space-y-2">
      <% Announcement.units.each_key do |unit_key| %>
        <label class="flex items-center gap-2 text-sm text-slate-700 dark:text-slate-300">
          <%= f.radio_button :unit, unit_key, class: "text-indigo-600 focus:ring-indigo-500" %>
          <%= announcement_unit_label(unit_key) %>
        </label>
      <% end %>
    </div>
  </fieldset>

  <div>
    <%= f.label :published_at, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.datetime_local_field :published_at,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :expires_at, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.datetime_local_field :expires_at,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    <p class="mt-1 text-xs text-slate-500 dark:text-slate-400"><%= t("views.admin.announcements.expires_at_hint") %></p>
  </div>

  <div class="flex items-start gap-2">
    <%= f.check_box :pinned, class: "mt-1 rounded border-slate-300 dark:border-slate-600 text-indigo-600 focus:ring-indigo-500" %>
    <div>
      <%= f.label :pinned, class: "text-sm text-slate-700 dark:text-slate-300" %>
      <p class="text-xs text-slate-500 dark:text-slate-400"><%= t("views.admin.announcements.pinned_hint") %></p>
    </div>
  </div>

  <div class="flex gap-3 pt-4">
    <%= f.submit class: "px-4 py-2 bg-indigo-600 dark:bg-indigo-500 text-white text-sm font-medium rounded-md
                          hover:bg-indigo-700 dark:hover:bg-indigo-600 shadow-sm cursor-pointer" %>
    <%= link_to t("views.shared.back"), admin_announcements_path,
        class: "px-4 py-2 text-sm text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400" %>
  </div>
<% end %>
