<%= form_with model: [:admin, announcement], class: "max-w-2xl" do |f| %>
  <%= render layout: "admin/shared/form_card", locals: { object: announcement } do %>
    <%= render layout: "admin/shared/form_section", locals: { title: t("views.admin.shared.basic_data") } do %>
      <%= admin_text_field f, :title, label: Announcement.human_attribute_name(:title), required: true %>
      <%= admin_text_area f, :body, label: Announcement.human_attribute_name(:body), rows: 5 %>
    <% end %>

    <%= render layout: "admin/shared/form_section", locals: { title: t("views.admin.shared.publication_settings") } do %>
      <fieldset class="space-y-2">
        <legend class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
          <%= Announcement.human_attribute_name(:unit) %>
        </legend>
        <div class="space-y-2">
          <% Announcement.units.each_key do |unit_key| %>
            <label class="flex items-center gap-2 text-sm text-slate-700 dark:text-slate-300">
              <%= f.radio_button :unit, unit_key, class: "text-indigo-600 focus:ring-indigo-500" %>
              <%= announcement_unit_label(unit_key) %>
            </label>
          <% end %>
        </div>
      </fieldset>

      <%= admin_datetime_field f, :published_at, label: Announcement.human_attribute_name(:published_at) %>
      <%= admin_datetime_field f, :expires_at,
          label: Announcement.human_attribute_name(:expires_at),
          hint: t("views.admin.announcements.expires_at_hint") %>
      <%= admin_checkbox f, :pinned,
          label: Announcement.human_attribute_name(:pinned),
          hint: t("views.admin.announcements.pinned_hint") %>
    <% end %>

    <%= render "admin/shared/form_actions", form: f, cancel_path: admin_announcements_path %>
  <% end %>
<% end %>
