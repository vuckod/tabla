<% content_for :title, t("views.titles.admin.document_popularity") %>

<%= render "admin/nav" %>

<div class="w-full">
  <h1 class="mb-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
    <%= t("views.admin.document_popularity.title") %>
  </h1>
  <p class="mb-6 text-sm text-slate-600 dark:text-slate-400">
    <%= t("views.admin.document_popularity.subtitle") %>
  </p>

  <div class="mb-6 flex flex-wrap gap-2">
    <% %w[all week month].each do |range| %>
      <%= link_to t("views.admin.document_popularity.ranges.#{range}"),
          admin_document_popularity_path(range: range == "all" ? nil : range),
          class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-md border " \
                 "#{@range_param == range ? 'bg-indigo-600 border-indigo-600 text-white' : 'border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 bg-white dark:bg-slate-800 hover:bg-slate-50 dark:hover:bg-slate-700'}" %>
    <% end %>
  </div>

  <div class="mb-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-4">
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
        <%= t("views.admin.document_popularity.total_views") %>
      </p>
      <p class="mt-1 text-2xl font-bold text-slate-900 dark:text-slate-100"><%= @total_views %></p>
    </div>
    <div class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-4">
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
        <%= t("views.admin.document_popularity.total_unique_viewers") %>
      </p>
      <p class="mt-1 text-2xl font-bold text-slate-900 dark:text-slate-100"><%= @total_unique_viewers %></p>
    </div>
  </div>

  <% if @documents.any? %>
    <div class="hidden md:block overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700">
      <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
        <thead class="bg-slate-50 dark:bg-slate-800">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">
              <%= Document.human_attribute_name(:title) %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">
              <%= t("views.admin.document_popularity.views") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">
              <%= t("views.admin.document_popularity.unique_viewers") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">
              <%= t("views.admin.document_popularity.last_viewed") %>
            </th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-slate-900 divide-y divide-slate-200 dark:divide-slate-700">
          <% @documents.each do |document| %>
            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
              <td class="px-4 py-3 text-sm font-medium text-slate-900 dark:text-slate-100">
                <%= link_to document.title, document_path(document),
                    class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
              </td>
              <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300 tabular-nums">
                <%= document.read_attribute(:views_count) %>
              </td>
              <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300 tabular-nums">
                <%= document.read_attribute(:unique_viewers_count) %>
              </td>
              <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300 whitespace-nowrap">
                <% last_at = document.read_attribute(:last_viewed_at) %>
                <%= last_at ? l(last_at, format: :short) : "—" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="md:hidden space-y-3">
      <% @documents.each do |document| %>
        <article class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-4">
          <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-100">
            <%= link_to document.title, document_path(document),
                class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
          </h2>
          <dl class="mt-2 grid grid-cols-2 gap-2 text-xs text-slate-600 dark:text-slate-400">
            <div>
              <dt class="font-medium"><%= t("views.admin.document_popularity.views") %></dt>
              <dd class="tabular-nums"><%= document.read_attribute(:views_count) %></dd>
            </div>
            <div>
              <dt class="font-medium"><%= t("views.admin.document_popularity.unique_viewers") %></dt>
              <dd class="tabular-nums"><%= document.read_attribute(:unique_viewers_count) %></dd>
            </div>
          </dl>
        </article>
      <% end %>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="mt-6 flex justify-center">
        <%= pagy_nav_tailwind(@pagy) %>
      </div>
    <% end %>
  <% else %>
    <%= render "admin/shared/empty_state",
        icon: :document,
        title: t("views.admin.document_popularity.empty_title"),
        message: t("views.admin.document_popularity.empty_message") %>
  <% end %>
</div>
