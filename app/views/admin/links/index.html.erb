<% content_for :title, t("views.admin.links.title") %>

<%= render "admin/nav" %>

<%= render "admin/shared/index_header",
    title: t("views.admin.links.title"),
    new_label: t("views.admin.links.new"),
    new_path: new_admin_link_path %>

<% if @links.any? %>
  <div class="overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700">
    <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
      <thead class="bg-slate-50 dark:bg-slate-800">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Link.human_attribute_name(:title) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= t("views.admin.links.category") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Link.human_attribute_name(:position) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= t("views.admin.links.flags") %></th>
          <th class="px-4 py-3 text-right text-xs font-medium text-slate-500 dark:text-slate-400 uppercase print:hidden"><%= t("views.shared.actions") %></th>
        </tr>
      </thead>
      <tbody class="bg-white dark:bg-slate-900 divide-y divide-slate-200 dark:divide-slate-700">
        <% @links.each do |link| %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
            <td class="px-4 py-3 text-sm font-medium text-slate-900 dark:text-slate-100">
              <%= link.title %>
              <div class="text-xs text-slate-500 dark:text-slate-400 truncate max-w-xs"><%= link.url %></div>
            </td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300"><%= link.link_category.name %></td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300"><%= link.position %></td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300">
              <% if link.internal_app? %>
                <span class="inline-block px-2 py-0.5 rounded text-xs bg-indigo-100 dark:bg-indigo-900/40 text-indigo-800 dark:text-indigo-200"><%= t("views.admin.links.internal_app") %></span>
              <% end %>
              <% if link.new_tab? %>
                <span class="inline-block px-2 py-0.5 rounded text-xs bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300"><%= t("views.admin.links.new_tab") %></span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right text-sm space-x-3 print:hidden">
              <%= link_to t("views.shared.edit"), edit_admin_link_path(link),
                  class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
              <% if policy(link).destroy? %>
                <%= button_to t("views.shared.delete"), admin_link_path(link),
                    method: :delete,
                    form: { data: { turbo_confirm: t("views.shared.confirm_delete") } },
                    class: "inline text-red-600 dark:text-red-400 hover:underline cursor-pointer" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "admin/shared/empty_state", message: t("views.admin.shared.empty_list") %>
<% end %>
