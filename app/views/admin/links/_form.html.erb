<%= form_with model: [:admin, link], class: "max-w-2xl" do |f| %>
  <%= render layout: "admin/shared/form_card", locals: { object: link } do %>
    <%= render layout: "admin/shared/form_section", locals: { title: t("views.admin.shared.basic_data") } do %>
      <%= admin_text_field f, :title, label: Link.human_attribute_name(:title), required: true %>
      <%= admin_text_field f, :url, label: Link.human_attribute_name(:url), input: :url_field, required: true %>
      <%= admin_text_area f, :description, label: Link.human_attribute_name(:description), rows: 2 %>
      <%= admin_select f, :link_category_id, nil,
          label: Link.human_attribute_name(:link_category),
          collection: LinkCategory.ordered %>
      <%= admin_text_field f, :position,
          label: Link.human_attribute_name(:position),
          input: :number_field,
          hint: t("views.admin.shared.position_hint") %>
    <% end %>

    <%= render layout: "admin/shared/form_section", locals: { title: t("views.admin.shared.display_settings") } do %>
      <%= admin_checkbox f, :internal_app, label: Link.human_attribute_name(:internal_app) %>
      <%= admin_checkbox f, :new_tab, label: Link.human_attribute_name(:new_tab) %>
    <% end %>

    <%= render "admin/shared/form_actions", form: f, cancel_path: admin_links_path %>
  <% end %>
<% end %>
