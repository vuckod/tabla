<%= form_with model: [:admin, link], class: "space-y-6 max-w-2xl" do |f| %>
  <% if link.errors.any? %>
    <div class="p-4 rounded-lg bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300 border border-red-200 dark:border-red-800">
      <ul class="list-disc list-inside text-sm">
        <% link.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.text_field :title, required: true,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :url, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.url_field :url, required: true,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.text_area :description, rows: 2,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :link_category_id, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.collection_select :link_category_id, LinkCategory.ordered, :id, :name, {},
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :position, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.number_field :position,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    <p class="mt-1 text-xs text-slate-500 dark:text-slate-400"><%= t("views.admin.shared.position_hint") %></p>
  </div>

  <div class="space-y-3">
    <div class="flex items-center gap-2">
      <%= f.check_box :internal_app, class: "rounded border-slate-300 dark:border-slate-600 text-indigo-600 focus:ring-indigo-500" %>
      <%= f.label :internal_app, class: "text-sm text-slate-700 dark:text-slate-300" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :new_tab, class: "rounded border-slate-300 dark:border-slate-600 text-indigo-600 focus:ring-indigo-500" %>
      <%= f.label :new_tab, class: "text-sm text-slate-700 dark:text-slate-300" %>
    </div>
  </div>

  <div class="flex gap-3 pt-4">
    <%= f.submit class: "px-4 py-2 bg-indigo-600 dark:bg-indigo-500 text-white text-sm font-medium rounded-md
                          hover:bg-indigo-700 dark:hover:bg-indigo-600 shadow-sm cursor-pointer" %>
    <%= link_to t("views.shared.back"), admin_links_path,
        class: "px-4 py-2 text-sm text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400" %>
  </div>
<% end %>
