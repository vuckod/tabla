<fieldset class="space-y-3" data-controller="nested-form">
  <legend class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
    <%= t("views.admin.phone_numbers.title") %>
  </legend>

  <div data-nested-form-target="container" class="space-y-3">
    <%= form.fields_for :phone_numbers do |phone_form| %>
      <%= render "admin/phone_numbers/fields", form: phone_form %>
    <% end %>
  </div>

  <button type="button"
          class="mt-2 px-3 py-2 text-sm font-medium text-indigo-600 dark:text-indigo-400
                 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 rounded-md"
          data-action="click->nested-form#add">
    <%= t("views.admin.phone_numbers.add") %>
  </button>

  <template data-nested-form-target="template">
    <%= form.fields_for :phone_numbers, PhoneNumber.new,
        child_index: "NEW_RECORD" do |phone_form| %>
      <%= render "admin/phone_numbers/fields", form: phone_form %>
    <% end %>
  </template>
</fieldset>
