<div data-nested-form-target="item"
     class="flex flex-col sm:flex-row sm:items-start gap-4 p-4 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900/50">
  <%= form.hidden_field :id %>
  <%= form.hidden_field :_destroy, value: false %>

  <div class="flex-1 min-w-0">
    <%= admin_text_field form, :number, label: PhoneNumber.human_attribute_name(:number) %>
  </div>

  <div class="sm:w-40 shrink-0">
    <%= admin_select form, :kind,
        PhoneNumber.kinds.keys.map { |k| [phone_kind_label(k), k] },
        label: PhoneNumber.human_attribute_name(:kind) %>
  </div>

  <div class="flex-1 min-w-0">
    <%= admin_text_field form, :label,
        label: PhoneNumber.human_attribute_name(:label),
        placeholder: t("views.admin.phone_numbers.label_hint") %>
  </div>

  <button type="button"
          class="shrink-0 px-3 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-md self-end sm:self-center"
          data-action="click->nested-form#remove">
    <%= t("views.shared.delete") %>
  </button>
</div>
