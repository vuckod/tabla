<%= form_with model: [:admin, link_category], class: "space-y-6 max-w-xl" do |f| %>
  <% if link_category.errors.any? %>
    <div class="p-4 rounded-lg bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300 border border-red-200 dark:border-red-800">
      <ul class="list-disc list-inside text-sm">
        <% link_category.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.text_field :name, required: true,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :position, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.number_field :position,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    <p class="mt-1 text-xs text-slate-500 dark:text-slate-400"><%= t("views.admin.shared.position_hint") %></p>
  </div>

  <div>
    <%= f.label :icon, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.text_field :icon, placeholder: t("views.admin.link_categories.icon_hint"),
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div class="flex gap-3 pt-4">
    <%= f.submit class: "px-4 py-2 bg-indigo-600 dark:bg-indigo-500 text-white text-sm font-medium rounded-md
                          hover:bg-indigo-700 dark:hover:bg-indigo-600 shadow-sm cursor-pointer" %>
    <%= link_to t("views.shared.back"), admin_link_categories_path,
        class: "px-4 py-2 text-sm text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400" %>
  </div>
<% end %>
