<%= form_with model: [:admin, link_category], class: "max-w-xl" do |f| %>
  <%= render layout: "admin/shared/form_card", locals: { object: link_category } do %>
    <%= render layout: "admin/shared/form_section", locals: { title: t("views.admin.shared.basic_data") } do %>
      <%= admin_text_field f, :name, label: LinkCategory.human_attribute_name(:name), required: true %>
      <%= admin_text_field f, :position,
          label: LinkCategory.human_attribute_name(:position),
          input: :number_field,
          hint: t("views.admin.shared.position_hint") %>
      <%= admin_icon_picker f, :icon,
          label: LinkCategory.human_attribute_name(:icon),
          hint: t("views.admin.link_categories.icon_hint") %>
    <% end %>

    <%= render "admin/shared/form_actions", form: f, cancel_path: admin_link_categories_path %>
  <% end %>
<% end %>
