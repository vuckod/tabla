<% content_for :title, t("views.admin.link_categories.title") %>

<%= render "admin/nav" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100">
    <%= t("views.admin.link_categories.title") %>
  </h1>
  <%= link_to t("views.admin.link_categories.new"), new_admin_link_category_path,
      class: "px-4 py-2 bg-indigo-600 dark:bg-indigo-500 text-white text-sm font-medium rounded-md
              hover:bg-indigo-700 dark:hover:bg-indigo-600 shadow-sm print:hidden" %>
</div>

<div class="overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700">
  <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
    <thead class="bg-slate-50 dark:bg-slate-800">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= LinkCategory.human_attribute_name(:name) %></th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= LinkCategory.human_attribute_name(:position) %></th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= t("views.admin.link_categories.links_count") %></th>
        <th class="px-4 py-3 text-right text-xs font-medium text-slate-500 dark:text-slate-400 uppercase print:hidden"><%= t("views.shared.actions") %></th>
      </tr>
    </thead>
    <tbody class="bg-white dark:bg-slate-900 divide-y divide-slate-200 dark:divide-slate-700">
      <% @link_categories.each do |category| %>
        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
          <td class="px-4 py-3 text-sm font-medium text-slate-900 dark:text-slate-100"><%= category.name %></td>
          <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300"><%= category.position %></td>
          <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300"><%= category.links.size %></td>
          <td class="px-4 py-3 text-right text-sm space-x-3 print:hidden">
            <%= link_to t("views.shared.edit"), edit_admin_link_category_path(category),
                class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
            <% if policy(category).destroy? %>
              <%= button_to t("views.shared.delete"), admin_link_category_path(category),
                  method: :delete,
                  form: { data: { turbo_confirm: t("views.shared.confirm_delete") } },
                  class: "inline text-red-600 dark:text-red-400 hover:underline cursor-pointer" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
