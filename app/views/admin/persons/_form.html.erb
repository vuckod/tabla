<%= form_with model: [:admin, person], class: "space-y-6 max-w-3xl" do |f| %>
  <% if person.errors.any? %>
    <div class="p-4 rounded-lg bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300 border border-red-200 dark:border-red-800">
      <ul class="list-disc list-inside text-sm">
        <% person.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :first_name, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
      <%= f.text_field :first_name,
          class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div>
      <%= f.label :last_name, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
      <%= f.text_field :last_name, required: true,
          class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>
  </div>

  <div>
    <%= f.label :position_title, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.text_field :position_title,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.email_field :email,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :location_id, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.collection_select :location_id, Location.ordered, :id, :name,
        { include_blank: t("views.admin.persons.no_location") },
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :active, class: "rounded border-slate-300 dark:border-slate-600 text-indigo-600 focus:ring-indigo-500" %>
    <%= f.label :active, class: "text-sm text-slate-700 dark:text-slate-300" %>
  </div>

  <%= render "admin/phone_numbers/nested_form", form: f %>

  <div class="flex gap-3 pt-4">
    <%= f.submit class: "px-4 py-2 bg-indigo-600 dark:bg-indigo-500 text-white text-sm font-medium rounded-md
                          hover:bg-indigo-700 dark:hover:bg-indigo-600 shadow-sm cursor-pointer" %>
    <%= link_to t("views.shared.back"), admin_persons_path,
        class: "px-4 py-2 text-sm text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400" %>
  </div>
<% end %>
