<% content_for :title, t("views.admin.persons.title") %>

<%= render "admin/nav" %>

<%= render "admin/shared/index_header",
    title: t("views.admin.persons.title"),
    new_label: t("views.admin.persons.new"),
    new_path: new_admin_person_path %>

<% if @persons.any? %>
  <div class="hidden md:block overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700">
    <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
      <thead class="bg-slate-50 dark:bg-slate-800">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Person.human_attribute_name(:last_name) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Person.human_attribute_name(:position_title) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Person.human_attribute_name(:location) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Person.human_attribute_name(:active) %></th>
          <th class="px-4 py-3 text-right text-xs font-medium text-slate-500 dark:text-slate-400 uppercase print:hidden"><%= t("views.shared.actions") %></th>
        </tr>
      </thead>
      <tbody class="bg-white dark:bg-slate-900 divide-y divide-slate-200 dark:divide-slate-700">
        <% @persons.each do |person| %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
            <td class="px-4 py-3 text-sm font-medium text-slate-900 dark:text-slate-100"><%= person.full_name %></td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300"><%= person.position_title %></td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300"><%= person.location&.name %></td>
            <td class="px-4 py-3 text-sm">
              <% if person.active? %>
                <span class="text-green-600 dark:text-green-400"><%= t("views.admin.persons.active") %></span>
              <% else %>
                <span class="text-slate-400"><%= t("views.admin.persons.inactive") %></span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right text-sm space-x-3 print:hidden">
              <%= link_to t("views.shared.edit"), edit_admin_person_path(person),
                  class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
              <% if policy(person).destroy? %>
                <%= button_to t("views.shared.delete"), admin_person_path(person),
                    method: :delete,
                    form: { data: { turbo_confirm: t("views.shared.confirm_delete") } },
                    class: "inline text-red-600 dark:text-red-400 hover:underline cursor-pointer" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="md:hidden space-y-3">
    <% @persons.each do |person| %>
      <article class="bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-4 shadow-sm">
        <div class="flex items-start justify-between gap-2 mb-2">
          <h3 class="font-semibold text-slate-900 dark:text-slate-100"><%= person.full_name %></h3>
          <% if person.active? %>
            <span class="text-xs font-medium text-green-600 dark:text-green-400 shrink-0"><%= t("views.admin.persons.active") %></span>
          <% else %>
            <span class="text-xs font-medium text-slate-400 shrink-0"><%= t("views.admin.persons.inactive") %></span>
          <% end %>
        </div>

        <dl class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-1 text-sm">
          <dt class="text-slate-600 dark:text-slate-400"><%= Person.human_attribute_name(:position_title) %></dt>
          <dd class="text-slate-800 dark:text-slate-200"><%= person.position_title.presence || "—" %></dd>
          <dt class="text-slate-600 dark:text-slate-400"><%= Person.human_attribute_name(:location) %></dt>
          <dd class="text-slate-800 dark:text-slate-200"><%= person.location&.name || "—" %></dd>
        </dl>

        <div class="mt-3 pt-3 border-t border-slate-100 dark:border-slate-700 flex flex-wrap gap-3 print:hidden">
          <%= link_to t("views.shared.edit"), edit_admin_person_path(person),
              class: "text-indigo-600 dark:text-indigo-400 hover:underline text-sm" %>
          <% if policy(person).destroy? %>
            <%= button_to t("views.shared.delete"), admin_person_path(person),
                method: :delete,
                form: { data: { turbo_confirm: t("views.shared.confirm_delete") } },
                class: "inline text-red-600 dark:text-red-400 hover:underline cursor-pointer text-sm" %>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
<% else %>
  <%= render "admin/shared/empty_state",
      icon: :users,
      title: t("views.admin.empty_states.persons.title"),
      message: t("views.admin.empty_states.persons.message"),
      action_path: new_admin_person_path,
      action_label: t("views.admin.empty_states.persons.action") %>
<% end %>
