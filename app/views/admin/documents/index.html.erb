<% content_for :title, t("views.admin.documents.title") %>

<%= render "admin/nav" %>

<%= render "admin/shared/index_header",
    title: t("views.admin.documents.title"),
    new_label: t("views.admin.documents.new"),
    new_path: new_admin_document_path %>

<% if @documents.any? %>
  <div class="hidden md:block overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700">
    <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
      <thead class="bg-slate-50 dark:bg-slate-800">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Document.human_attribute_name(:title) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= t("views.admin.documents.category") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Document.human_attribute_name(:published_at) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= t("views.admin.documents.flags") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= t("views.admin.documents.ocr_status") %></th>
          <th class="px-4 py-3 text-right text-xs font-medium text-slate-500 dark:text-slate-400 uppercase print:hidden"><%= t("views.shared.actions") %></th>
        </tr>
      </thead>
      <tbody class="bg-white dark:bg-slate-900 divide-y divide-slate-200 dark:divide-slate-700">
        <% @documents.each do |document| %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
            <td class="px-4 py-3 text-sm font-medium text-slate-900 dark:text-slate-100">
              <%= document.title %>
              <% unless document.published? %>
                <span class="ml-2 text-xs text-amber-600 dark:text-amber-400"><%= t("views.admin.documents.scheduled") %></span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300"><%= document.document_category.name %></td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300">
              <%= document.published_at ? l(document.published_at, format: :short) : "—" %>
            </td>
            <td class="px-4 py-3 text-sm space-x-1">
              <% if document.internal_only? %>
                <span class="inline-block px-2 py-0.5 rounded text-xs bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-200"><%= t("views.documents.internal") %></span>
              <% end %>
              <% if document.notify_staff? %>
                <span class="inline-block px-2 py-0.5 rounded text-xs bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300"><%= t("views.admin.documents.notify_staff") %></span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm">
              <%= document_ocr_status_badge(document) %>
            </td>
            <td class="px-4 py-3 text-right text-sm space-x-3 print:hidden">
              <% if policy(document).audit_history? %>
                <%= link_to t("views.admin.documents.audit_history"), audit_history_admin_document_path(document),
                    data: { turbo_frame: "modal" },
                    class: "text-slate-600 dark:text-slate-400 hover:underline" %>
              <% end %>
              <%= link_to t("views.shared.edit"), edit_admin_document_path(document),
                  class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
              <% if policy(document).destroy? %>
                <%= button_to t("views.shared.delete"), admin_document_path(document),
                    method: :delete,
                    form: { data: { turbo_confirm: t("views.shared.confirm_delete") } },
                    class: "inline text-red-600 dark:text-red-400 hover:underline cursor-pointer" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="md:hidden space-y-3">
    <% @documents.each do |document| %>
      <article class="bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-4 shadow-sm">
        <div class="flex items-start justify-between gap-2 mb-2">
          <h3 class="font-semibold text-slate-900 dark:text-slate-100">
            <%= document.title %>
            <% unless document.published? %>
              <span class="ml-1 text-xs font-normal text-amber-600 dark:text-amber-400"><%= t("views.admin.documents.scheduled") %></span>
            <% end %>
          </h3>
          <div class="flex flex-wrap justify-end gap-1 shrink-0">
            <%= document_ocr_status_badge(document) %>
          </div>
        </div>

        <div class="flex flex-wrap gap-1 mb-2">
          <% if document.internal_only? %>
            <span class="inline-block px-2 py-0.5 rounded text-xs bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-200"><%= t("views.documents.internal") %></span>
          <% end %>
          <% if document.notify_staff? %>
            <span class="inline-block px-2 py-0.5 rounded text-xs bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300"><%= t("views.admin.documents.notify_staff") %></span>
          <% end %>
        </div>

        <dl class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-1 text-sm">
          <dt class="text-slate-600 dark:text-slate-400"><%= t("views.admin.documents.category") %></dt>
          <dd class="text-slate-800 dark:text-slate-200"><%= document.document_category.name %></dd>
          <dt class="text-slate-600 dark:text-slate-400"><%= Document.human_attribute_name(:published_at) %></dt>
          <dd class="text-slate-800 dark:text-slate-200"><%= document.published_at ? l(document.published_at, format: :short) : "—" %></dd>
        </dl>

        <div class="mt-3 pt-3 border-t border-slate-100 dark:border-slate-700 flex flex-wrap gap-3 print:hidden">
          <% if policy(document).audit_history? %>
            <%= link_to t("views.admin.documents.audit_history"), audit_history_admin_document_path(document),
                data: { turbo_frame: "modal" },
                class: "text-slate-600 dark:text-slate-400 hover:underline text-sm" %>
          <% end %>
          <%= link_to t("views.shared.edit"), edit_admin_document_path(document),
              class: "text-indigo-600 dark:text-indigo-400 hover:underline text-sm" %>
          <% if policy(document).destroy? %>
            <%= button_to t("views.shared.delete"), admin_document_path(document),
                method: :delete,
                form: { data: { turbo_confirm: t("views.shared.confirm_delete") } },
                class: "inline text-red-600 dark:text-red-400 hover:underline cursor-pointer text-sm" %>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
<% else %>
  <%= render "admin/shared/empty_state", message: t("views.admin.shared.empty_list") %>
<% end %>
