<%= form_with model: [:admin, document], html: { multipart: true }, class: "space-y-6 max-w-2xl" do |f| %>
  <% if document.errors.any? %>
    <div class="p-4 rounded-lg bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300 border border-red-200 dark:border-red-800">
      <ul class="list-disc list-inside text-sm">
        <% document.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.text_field :title, required: true,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.text_area :description, rows: 4,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :document_category_id, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.collection_select :document_category_id, DocumentCategory.ordered, :id, :name, {},
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :file, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <% if document.file.attached? %>
      <p class="text-sm text-slate-600 dark:text-slate-400 mb-2">
        <%= t("views.admin.documents.current_file") %>: <%= document.file.filename %>
      </p>
    <% end %>
    <%= f.file_field :file, accept: "application/pdf",
        class: "block w-full text-sm text-slate-600 dark:text-slate-300
                file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0
                file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700
                dark:file:bg-indigo-900/30 dark:file:text-indigo-300
                hover:file:bg-indigo-100 dark:hover:file:bg-indigo-900/50" %>
    <p class="mt-1 text-xs text-slate-500 dark:text-slate-400"><%= t("views.admin.documents.file_hint") %></p>
  </div>

  <div>
    <%= f.label :published_at, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
    <%= f.datetime_local_field :published_at,
        class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    <p class="mt-1 text-xs text-slate-500 dark:text-slate-400"><%= t("views.admin.documents.published_at_hint") %></p>
  </div>

  <div class="space-y-3">
    <div class="flex items-start gap-2">
      <%= f.check_box :internal_only, class: "mt-1 rounded border-slate-300 dark:border-slate-600 text-indigo-600 focus:ring-indigo-500" %>
      <div>
        <%= f.label :internal_only, class: "text-sm text-slate-700 dark:text-slate-300" %>
        <p class="text-xs text-slate-500 dark:text-slate-400"><%= t("views.admin.documents.internal_only_hint") %></p>
      </div>
    </div>

    <div class="flex items-start gap-2">
      <%= f.check_box :notify_staff, class: "mt-1 rounded border-slate-300 dark:border-slate-600 text-indigo-600 focus:ring-indigo-500" %>
      <div>
        <%= f.label :notify_staff, class: "text-sm text-slate-700 dark:text-slate-300" %>
        <p class="text-xs text-slate-500 dark:text-slate-400"><%= t("views.admin.documents.notify_staff_hint") %></p>
      </div>
    </div>
  </div>

  <div class="flex gap-3 pt-4">
    <%= f.submit (document.persisted? ? t("helpers.submit.update") : t("helpers.submit.document.create")),
        class: "px-4 py-2 bg-indigo-600 dark:bg-indigo-500 text-white text-sm font-medium rounded-md
                hover:bg-indigo-700 dark:hover:bg-indigo-600 shadow-sm cursor-pointer" %>
    <%= link_to t("views.shared.back"), admin_documents_path,
        class: "px-4 py-2 text-sm text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400" %>
  </div>
<% end %>
