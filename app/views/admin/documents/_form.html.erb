<%= form_with model: [:admin, document], html: { multipart: true }, class: "max-w-2xl" do |f| %>
  <%= render layout: "admin/shared/form_card", locals: { object: document } do %>
    <%= render layout: "admin/shared/form_section", locals: { title: t("views.admin.shared.basic_data") } do %>
      <%= admin_text_field f, :title, label: Document.human_attribute_name(:title), required: true %>
      <%= admin_text_area f, :description, label: Document.human_attribute_name(:description), rows: 4 %>
      <%= admin_select f, :document_category_id, nil,
          label: Document.human_attribute_name(:document_category),
          collection: DocumentCategory.ordered %>

      <div class="space-y-1">
        <% if document.file.attached? %>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            <%= t("views.admin.documents.current_file") %>: <%= document.file.filename %>
          </p>
        <% end %>
        <%= admin_file_field f, :file,
            label: Document.human_attribute_name(:file),
            accept: "application/pdf",
            hint: t("views.admin.documents.file_hint") %>
      </div>
    <% end %>

    <%= render layout: "admin/shared/form_section", locals: { title: t("views.admin.shared.publication_settings") } do %>
      <%= admin_datetime_field f, :published_at,
          label: Document.human_attribute_name(:published_at),
          hint: t("views.admin.documents.published_at_hint") %>
      <%= admin_checkbox f, :internal_only,
          label: Document.human_attribute_name(:internal_only),
          hint: t("views.admin.documents.internal_only_hint") %>
      <%= admin_checkbox f, :notify_staff,
          label: Document.human_attribute_name(:notify_staff),
          hint: t("views.admin.documents.notify_staff_hint") %>
    <% end %>

    <%= render "admin/shared/form_actions",
        form: f,
        cancel_path: admin_documents_path,
        submit_label: (document.persisted? ? t("helpers.submit.update") : t("helpers.submit.document.create")) %>
  <% end %>
<% end %>
