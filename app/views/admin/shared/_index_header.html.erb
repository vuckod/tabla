<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100">
    <%= title %>
  </h1>

  <% if local_assigns[:new_path].present? %>
    <%= link_to new_label, new_path,
        class: "inline-flex items-center justify-center px-4 py-2 bg-indigo-600 dark:bg-indigo-500 " \
               "text-white text-sm font-medium rounded-md hover:bg-indigo-700 dark:hover:bg-indigo-600 " \
               "shadow-sm print:hidden" %>
  <% end %>
</div>
