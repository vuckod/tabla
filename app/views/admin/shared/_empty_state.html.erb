<%# locals: icon:, title:, message: nil, action_path: nil, action_label: nil %>
<% action = if local_assigns[:action_path].present? && local_assigns[:action_label].present?
  link_to action_label, action_path,
      class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-md " \
             "bg-indigo-600 dark:bg-indigo-500 text-white " \
             "hover:bg-indigo-700 dark:hover:bg-indigo-600 shadow-sm print:hidden"
end %>

<%= render "shared/empty_state",
    icon: icon,
    title: title,
    message: local_assigns[:message],
    action: action %>
