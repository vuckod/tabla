<% if turbo_frame_request? %>
  <%= turbo_frame_tag "inline_document_category" do %>
    <%= render "inline_form", document_category: @document_category %>
  <% end %>
<% else %>
  <% content_for :title, t("views.titles.admin.document_category_new") %>

  <%= render "admin/nav" %>

  <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-6">
    <%= t("views.admin.document_categories.new") %>
  </h1>

  <%= render "form", document_category: @document_category %>
<% end %>
