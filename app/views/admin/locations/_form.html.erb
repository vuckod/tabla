<%= form_with model: [:admin, location], class: "max-w-3xl" do |f| %>
  <%= render layout: "admin/shared/form_card", locals: { object: location } do %>
    <%= render layout: "admin/shared/form_section", locals: { title: t("views.admin.shared.basic_data") } do %>
      <%= admin_text_field f, :name, label: Location.human_attribute_name(:name), required: true %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <%= admin_select f, :kind,
            Location.kinds.keys.map { |k| [location_kind_label(k), k] },
            label: Location.human_attribute_name(:kind) %>
        <%= admin_text_field f, :short_code, label: Location.human_attribute_name(:short_code) %>
      </div>

      <%= admin_text_field f, :phone, label: Location.human_attribute_name(:phone) %>
      <%= admin_text_area f, :schedule_info,
          label: Location.human_attribute_name(:schedule_info),
          rows: 2,
          placeholder: t("views.admin.locations.schedule_hint") %>
      <%= admin_text_field f, :address, label: Location.human_attribute_name(:address) %>
      <%= admin_text_field f, :position,
          label: Location.human_attribute_name(:position),
          input: :number_field,
          hint: t("views.admin.shared.position_hint") %>
    <% end %>

    <%= render "admin/phone_numbers/nested_form", form: f %>

    <%= render "admin/shared/form_actions", form: f, cancel_path: admin_locations_path %>
  <% end %>
<% end %>
