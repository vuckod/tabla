<% content_for :title, t("views.admin.locations.title") %>

<%= render "admin/nav" %>

<%= render "admin/shared/index_header",
    title: t("views.admin.locations.title"),
    new_label: t("views.admin.locations.new"),
    new_path: new_admin_location_path %>

<% if @locations.any? %>
  <div class="overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700">
    <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
      <thead class="bg-slate-50 dark:bg-slate-800">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Location.human_attribute_name(:name) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Location.human_attribute_name(:kind) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Location.human_attribute_name(:short_code) %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase"><%= Location.human_attribute_name(:schedule_info) %></th>
          <th class="px-4 py-3 text-right text-xs font-medium text-slate-500 dark:text-slate-400 uppercase print:hidden"><%= t("views.shared.actions") %></th>
        </tr>
      </thead>
      <tbody class="bg-white dark:bg-slate-900 divide-y divide-slate-200 dark:divide-slate-700">
        <% @locations.each do |location| %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
            <td class="px-4 py-3 text-sm font-medium text-slate-900 dark:text-slate-100"><%= location.name %></td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300"><%= location_kind_label(location.kind) %></td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300"><%= location.short_code %></td>
            <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300"><%= location.schedule_info %></td>
            <td class="px-4 py-3 text-right text-sm space-x-3 print:hidden">
              <%= link_to t("views.shared.edit"), edit_admin_location_path(location),
                  class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
              <% if policy(location).destroy? %>
                <%= button_to t("views.shared.delete"), admin_location_path(location),
                    method: :delete,
                    form: { data: { turbo_confirm: t("views.shared.confirm_delete") } },
                    class: "inline text-red-600 dark:text-red-400 hover:underline cursor-pointer" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "admin/shared/empty_state", message: t("views.admin.shared.empty_list") %>
<% end %>
