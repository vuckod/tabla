<% content_for :title, t("views.titles.admin.analytics") %>

<%= render "admin/nav" %>

<div class="w-full">
  <h1 class="mb-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100"><%= t("views.admin.analytics.title") %></h1>
  <p class="mb-6 text-sm text-slate-600 dark:text-slate-400"><%= t("views.admin.analytics.subtitle") %></p>

  <% filters_active = params[:q].present? || params[:user_id].present? || params[:ip].present? || params[:start_date].present? || params[:end_date].present? %>
  <% filter_ctrl = "h-10 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:border-slate-600 dark:bg-slate-900/60 dark:text-slate-100" %>
  <% turbo_frame = "analytics_main" %>

  <%= form_with url: admin_analytics_path, method: :get,
        data: {
          controller: "auto-submit",
          turbo_frame: turbo_frame,
          turbo_action: "advance",
          action: "input->auto-submit#debouncedSubmit change->auto-submit#submitImmediate"
        },
        class: "mb-6" do %>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-800 dark:bg-slate-900/50">
      <p class="mb-4 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400"><%= t("views.admin.analytics.filters") %></p>
      <div class="grid grid-cols-1 gap-4">
        <div class="col-span-full">
          <%= label_tag :q, t("views.admin.analytics.search"), class: "mb-1 block text-xs font-medium text-slate-600 dark:text-slate-400" %>
          <div class="relative">
            <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <%= text_field_tag :q,
                  params[:q],
                  placeholder: t("views.admin.analytics.search_placeholder"),
                  autocomplete: "off",
                  class: "#{filter_ctrl} pl-10 pr-3 text-slate-900 placeholder:text-slate-400 dark:placeholder:text-slate-500" %>
          </div>
        </div>
        <div class="col-span-full grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-4">
          <div>
            <%= label_tag :user_id, User.model_name.human, class: "mb-1 block text-xs font-medium text-slate-600 dark:text-slate-400" %>
            <%= select_tag :user_id,
                  options_for_select([["#{t('views.admin.analytics.all_users')}", ""]] + User.active.order(:username).map { |u| ["#{u.polno_ime} (#{u.username})", u.id] }, params[:user_id]),
                  class: "#{filter_ctrl} px-3 text-slate-900" %>
          </div>
          <div>
            <%= label_tag :ip, t("views.admin.analytics.ip"), class: "mb-1 block text-xs font-medium text-slate-600 dark:text-slate-400" %>
            <%= text_field_tag :ip, params[:ip],
                  placeholder: t("views.admin.analytics.ip_placeholder"),
                  class: "#{filter_ctrl} px-3 text-slate-900 placeholder:text-slate-400 dark:placeholder:text-slate-500" %>
          </div>
          <div>
            <%= label_tag :start_date, t("views.admin.analytics.from"), class: "mb-1 block text-xs font-medium text-slate-600 dark:text-slate-400" %>
            <%= date_field_tag :start_date, params[:start_date], class: "#{filter_ctrl} px-3 text-slate-900" %>
          </div>
          <div>
            <%= label_tag :end_date, t("views.admin.analytics.to"), class: "mb-1 block text-xs font-medium text-slate-600 dark:text-slate-400" %>
            <%= date_field_tag :end_date, params[:end_date], class: "#{filter_ctrl} px-3 text-slate-900" %>
          </div>
        </div>
      </div>
      <div class="mt-5 flex flex-wrap items-center justify-end gap-2">
        <%= submit_tag t("views.admin.analytics.filter_submit"), class: "inline-flex h-10 cursor-pointer items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm transition hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-400" %>
        <% if filters_active %>
          <%= link_to t("views.admin.analytics.clear_filters"), admin_analytics_path,
                class: "inline-flex h-10 items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm transition hover:bg-slate-100 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700",
                data: { turbo_frame: "_top" } %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= turbo_frame_tag turbo_frame do %>
    <div class="mb-10 rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400"><%= t("views.admin.analytics.os_stats") %></h2>
      <% if @os_stats.blank? %>
        <p class="mt-3 text-sm text-slate-500 dark:text-slate-400"><%= t("views.admin.shared.empty_list") %></p>
      <% else %>
        <ul class="mt-4 divide-y divide-slate-100 dark:divide-slate-800">
          <% @os_stats.sort_by { |_k, v| -v }.each do |os, cnt| %>
            <li class="flex items-center justify-between py-2 text-sm transition-colors hover:bg-slate-50/80 dark:hover:bg-slate-800/50">
              <span class="text-slate-800 dark:text-slate-200"><%= os.presence || "—" %></span>
              <span class="rounded-full bg-indigo-100 px-2.5 py-0.5 text-xs font-semibold text-indigo-800 dark:bg-indigo-950/60 dark:text-indigo-200"><%= cnt %></span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>

    <div class="mb-10 hidden md:block overflow-x-auto rounded-xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <div class="flex flex-wrap items-center justify-between gap-2 border-b border-slate-200 bg-slate-50/80 px-4 py-3 dark:border-slate-800 dark:bg-slate-950/50">
        <h2 class="text-sm font-semibold text-slate-700 dark:text-slate-300"><%= t("views.admin.analytics.visits_log") %></h2>
      </div>
      <table class="w-full table-auto divide-y divide-slate-100 text-left text-sm dark:divide-slate-800">
        <thead class="border-b border-slate-200 text-xs font-semibold uppercase text-slate-500 dark:border-slate-800 dark:text-slate-400">
          <tr>
            <th class="px-4 py-3"><%= User.model_name.human %></th>
            <th class="px-4 py-3">IP</th>
            <th class="px-4 py-3">OS</th>
            <th class="px-4 py-3"><%= t("views.admin.analytics.browser") %></th>
            <th class="px-4 py-3"><%= t("views.admin.analytics.started_at") %></th>
          </tr>
        </thead>
        <tbody>
          <% @zadnji_obiski.each do |v| %>
            <tr class="transition-colors hover:bg-slate-50 dark:hover:bg-slate-800/50">
              <td class="px-4 py-2 text-slate-800 dark:text-slate-200"><%= v.user&.polno_ime.presence || v.user&.username || "—" %></td>
              <td class="px-4 py-2 text-slate-600 dark:text-slate-400"><%= v.ip.presence || "—" %></td>
              <td class="px-4 py-2 text-slate-600 dark:text-slate-400"><%= v.os.presence || "—" %></td>
              <td class="px-4 py-2 text-slate-600 dark:text-slate-400"><%= v.browser.presence || "—" %></td>
              <td class="whitespace-nowrap px-4 py-2 text-slate-600 dark:text-slate-400"><%= v.started_at&.strftime("%d.%m.%Y %H:%M") || "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mb-10 md:hidden space-y-3">
      <h2 class="text-sm font-semibold text-slate-700 dark:text-slate-300"><%= t("views.admin.analytics.visits_log") %></h2>
      <% @zadnji_obiski.each do |v| %>
        <article class="bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-4 shadow-sm">
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="font-semibold text-slate-900 dark:text-slate-100">
              <%= v.user&.polno_ime.presence || v.user&.username || "—" %>
            </h3>
            <span class="text-xs text-slate-500 dark:text-slate-400 shrink-0 whitespace-nowrap">
              <%= v.started_at&.strftime("%d.%m.%Y %H:%M") || "—" %>
            </span>
          </div>
          <dl class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-1 text-sm">
            <dt class="text-slate-600 dark:text-slate-400">IP</dt>
            <dd class="text-slate-800 dark:text-slate-200"><%= v.ip.presence || "—" %></dd>
            <dt class="text-slate-600 dark:text-slate-400">OS</dt>
            <dd class="text-slate-800 dark:text-slate-200"><%= v.os.presence || "—" %></dd>
            <dt class="text-slate-600 dark:text-slate-400"><%= t("views.admin.analytics.browser") %></dt>
            <dd class="text-slate-800 dark:text-slate-200"><%= v.browser.presence || "—" %></dd>
          </dl>
        </article>
      <% end %>
    </div>

    <% if @pagy_visits.pages > 1 %>
      <div class="mb-10 mt-8 flex justify-center pb-10">
        <%== pagy_nav_tailwind(@pagy_visits, data: { turbo_frame: turbo_frame, turbo_action: "advance" }) %>
      </div>
    <% end %>

    <div class="hidden md:block overflow-x-auto rounded-xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <div class="flex flex-wrap items-center justify-between gap-2 border-b border-slate-200 bg-slate-50/80 px-4 py-3 dark:border-slate-800 dark:bg-slate-950/50">
        <h2 class="text-sm font-semibold text-slate-700 dark:text-slate-300"><%= t("views.admin.analytics.events_log") %></h2>
      </div>
      <table class="w-full table-auto divide-y divide-slate-100 text-left text-sm dark:divide-slate-800">
        <thead class="border-b border-slate-200 text-xs font-semibold uppercase text-slate-500 dark:border-slate-800 dark:text-slate-400">
          <tr>
            <th class="px-4 py-3"><%= t("views.admin.analytics.time") %></th>
            <th class="px-4 py-3"><%= t("views.admin.analytics.event_name") %></th>
            <th class="px-4 py-3"><%= User.model_name.human %></th>
            <th class="px-4 py-3"><%= t("views.admin.analytics.properties") %></th>
          </tr>
        </thead>
        <tbody>
          <% @zadnji_dogodki.each do |e| %>
            <tr class="transition-colors hover:bg-slate-50 dark:hover:bg-slate-800/50">
              <td class="whitespace-nowrap px-4 py-2 text-slate-600 dark:text-slate-400"><%= e.time&.strftime("%d.%m.%Y %H:%M:%S") || "—" %></td>
              <td class="px-4 py-2 font-medium text-slate-800 dark:text-slate-200"><%= e.name %></td>
              <td class="px-4 py-2 text-slate-600 dark:text-slate-400"><%= e.user&.polno_ime.presence || e.user&.username || "—" %></td>
              <td class="max-w-md truncate px-4 py-2 text-xs text-slate-500 dark:text-slate-400" title="<%= e.properties %>"><%= e.properties %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="md:hidden space-y-3">
      <h2 class="text-sm font-semibold text-slate-700 dark:text-slate-300"><%= t("views.admin.analytics.events_log") %></h2>
      <% @zadnji_dogodki.each do |e| %>
        <article class="bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-4 shadow-sm">
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="font-semibold text-slate-900 dark:text-slate-100"><%= e.name %></h3>
            <span class="text-xs text-slate-500 dark:text-slate-400 shrink-0 whitespace-nowrap">
              <%= e.time&.strftime("%d.%m.%Y %H:%M:%S") || "—" %>
            </span>
          </div>
          <dl class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-1 text-sm">
            <dt class="text-slate-600 dark:text-slate-400"><%= User.model_name.human %></dt>
            <dd class="text-slate-800 dark:text-slate-200"><%= e.user&.polno_ime.presence || e.user&.username || "—" %></dd>
            <dt class="text-slate-600 dark:text-slate-400"><%= t("views.admin.analytics.properties") %></dt>
            <dd class="text-xs text-slate-500 dark:text-slate-400 break-all"><%= e.properties %></dd>
          </dl>
        </article>
      <% end %>
    </div>

    <% if @pagy_events.pages > 1 %>
      <div class="mt-8 flex justify-center pb-10">
        <%== pagy_nav_tailwind(@pagy_events, data: { turbo_frame: turbo_frame, turbo_action: "advance" }) %>
      </div>
    <% end %>
  <% end %>
</div>
