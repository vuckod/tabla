  </svg>
  <%= t("views.layouts.header.directory") %>
<% end %>

<%= main_nav_link links_path, mobile: mobile do %>
  <svg class="<%= icon_classes %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
  </svg>
  <%= t("views.layouts.header.links") %>
<% end %>

<%= main_nav_link documents_path, mobile: mobile do %>
  <svg class="<%= icon_classes %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a2.25 2.25 0 0 0-1.5-2.122v0a2.25 2.25 0 0 0-1.5-2.122H6.75c-1.036 0-1.875.84-1.875 1.875v11.25c0 1.035.84 1.875 1.875 1.875h8.25a2.25 2.25 0 0 0 2.25-2.25v-1.125M9 12.75h6.75M9 15.75h4.5" />
  </svg>
  <%= t("views.layouts.header.documents") %>
  <%= nav_documents_badge_html %>
<% end %>

