<% mobile = local_assigns.fetch(:mobile, false) %>
<% icon_classes = "h-4 w-4 shrink-0" %>

<%= main_nav_link root_path, mobile: mobile do %>
  <svg class="<%= icon_classes %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
