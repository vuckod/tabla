<header class="sticky top-0 z-40 bg-gradient-to-r from-white via-indigo-50/50 to-white
               dark:from-slate-800 dark:via-slate-800 dark:to-slate-800
               border-b border-slate-200 dark:border-slate-700 shadow-sm print:hidden print:static"
        data-controller="mobile-menu">
  <div class="<%= page_container_classes %>">
    <div class="flex items-center justify-between h-16 gap-3">
      <div class="flex items-center gap-4 lg:gap-8 min-w-0 shrink-0">
        <%= link_to root_path,
            class: "flex items-center gap-3 hover:text-indigo-600 dark:hover:text-indigo-400 shrink-0 min-w-0" do %>
          <svg class="h-8 w-8 text-indigo-600 dark:text-indigo-400 shrink-0" fill="none"
               viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" />
          </svg>
          <span class="block leading-tight min-w-0">
            <span class="text-base sm:text-lg font-semibold text-slate-900 dark:text-slate-100">
              <%= t("views.layouts.header.title") %>
            </span>
            <span class="block text-xs text-slate-500 dark:text-slate-400 font-normal">
              <%= t("views.layouts.header.subtitle") %>
            </span>
          </span>
        <% end %>

        <nav class="hidden lg:flex lg:items-center lg:gap-1" aria-label="<%= t("views.layouts.header.main_nav") %>">
          <%= render "layouts/nav_links" %>
        </nav>
      </div>

      <div class="hidden md:flex flex-1 max-w-md mx-2">
        <%= render "layouts/search_form" %>
      </div>

      <div class="flex items-center gap-2 shrink-0">
        <time datetime="<%= Date.current.iso8601 %>"
              class="hidden lg:block text-sm text-slate-500 dark:text-slate-400 mr-2 whitespace-nowrap">
          <%= l(Date.current, format: :header) %>
        </time>

        <div class="hidden sm:flex sm:items-center sm:gap-4">
          <%= render "layouts/header_actions" %>
        </div>

        <button type="button"
                class="lg:hidden inline-flex items-center justify-center p-2 rounded-md
                       text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700
                       focus:outline-none focus:ring-2 focus:ring-indigo-500"
                data-mobile-menu-target="button"
                data-action="click->mobile-menu#toggle"
                aria-expanded="false"
                aria-controls="mobile-menu"
                aria-label="<%= t("views.layouts.header.menu_toggle") %>">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>

    <nav id="mobile-menu"
         class="hidden lg:hidden pb-4 space-y-3 border-t border-slate-200 dark:border-slate-700 pt-4"
         data-mobile-menu-target="menu"
         aria-label="<%= t("views.layouts.header.main_nav") %>">
      <div class="md:hidden">
        <%= render "layouts/search_form" %>
      </div>

      <%= render "layouts/nav_links", mobile: true %>
      <div class="pt-4 mt-4 border-t border-slate-200 dark:border-slate-700 space-y-2">
        <%= render "layouts/header_actions", mobile: true %>
      </div>
    </nav>
  </div>
</header>
