<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 space-y-2 print:hidden">
  <% flash.each do |type, message| %>
    <% next if message.blank? %>

    <% color_classes = case type.to_s
       when "notice"
         "bg-green-50 dark:bg-green-900/30 text-green-800 dark:text-green-200 border-green-200 dark:border-green-800"
       when "alert"
         "bg-red-50 dark:bg-red-900/30 text-red-800 dark:text-red-200 border-red-200 dark:border-red-800"
       else
         "bg-slate-50 dark:bg-slate-800 text-slate-800 dark:text-slate-200 border-slate-200 dark:border-slate-700"
       end %>

    <div class="flex items-center justify-between gap-4 p-4 rounded-lg border <%= color_classes %>"
         role="alert"
         data-controller="flash">
      <p class="text-sm font-medium"><%= message %></p>
      <button type="button"
              class="shrink-0 p-1 rounded hover:bg-black/5 dark:hover:bg-white/10"
              data-action="click->flash#dismiss"
              aria-label="<%= t("views.layouts.flash.dismiss") %>">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  <% end %>
</div>
