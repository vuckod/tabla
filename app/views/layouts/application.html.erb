<!DOCTYPE html>
<html lang="sl" data-controller="dark-mode">
  <head>
    <title>
      <% if content_for?(:title) %>
        <%= content_for(:title) %> | <%= t("views.titles.app_name") %>
      <% else %>
        <%= t("views.titles.app_name") %>
      <% end %>
    </title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#1e1b4b">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("views.layouts.header.page_title") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= pwa_manifest %>

    <%= yield :head %>

    <script>
      if (localStorage.getItem("tabla-dark-mode") === "true") {
        document.documentElement.classList.add("dark");
      }
    </script>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon-192.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script>
      window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
          navigator.serviceWorker.register("<%= pwa_service_worker_path %>").catch(function (err) {
            console.warn("SW registracija ni uspela:", err);
          });
        }
      });
    </script>
  </head>

  <body class="bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-slate-100 min-h-screen flex flex-col">
    <a href="#main-content"
       class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100]
              focus:px-4 focus:py-2 focus:bg-indigo-600 focus:text-white focus:rounded-md focus:shadow-lg">
      <%= t("views.layouts.skip_to_content") %>
    </a>

    <%# Header je viden VSEM (tudi neprijavljenim) — navigacija je javna, tipka za prijavo
        je v header_actions za neprijavljene. %>
    <%= render "layouts/header" %>

    <% if flash.any? %>
      <%= render "layouts/flash" %>
    <% end %>

    <main id="main-content" tabindex="-1" class="<%= page_container_classes %> py-6 flex-1">
      <%= yield %>
    </main>

    <footer class="border-t border-slate-200 bg-white/50 py-4 text-center text-xs text-slate-400
                   print:hidden dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-500"
            role="contentinfo">
      <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 px-4">
        <span><span class="font-medium text-slate-500 dark:text-slate-400">Verzija</span> <%= TABLA_VERSION %></span>
        <span><span class="font-medium text-slate-500 dark:text-slate-400">Zagon</span> <%= RELEASE_DATE %></span>
        <span>© <%= Time.zone.now.year %> Dejan Vučko</span>
      </div>
    </footer>

    <%= turbo_frame_tag "modal" %>
  </body>
</html>
