<% mobile = local_assigns.fetch(:mobile, false) %>

<button type="button"
        class="<%= mobile ? "w-full text-left" : "" %> p-2 rounded-md text-slate-600 dark:text-slate-300
               hover:bg-slate-100 dark:hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500"
        data-action="click->dark-mode#toggle"
        aria-label="<%= t("views.layouts.header.dark_mode_toggle") %>">
  <span class="sr-only"><%= t("views.layouts.header.dark_mode_toggle") %></span>
  <%# Sonce (prikaži v dark načinu) %>
  <svg class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
  </svg>
  <%# Luna (prikaži v light načinu) %>
  <svg class="h-5 w-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
  </svg>
</button>

<% if current_user %>
  <span class="<%= mobile ? "block px-3 py-2 text-sm text-slate-600 dark:text-slate-300" : "text-sm text-slate-600 dark:text-slate-300" %>">
    <%= current_user.polno_ime %>
  </span>

  <%= link_to t("views.sessions.logout"), logout_path,
      class: "#{mobile ? "block " : ""}px-3 py-2 text-sm font-medium rounded-md
              text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-700
              hover:text-red-600 dark:hover:text-red-400" %>
<% end %>
