<% content_for :title, t("views.titles.document_show", title: @document.title) %>

<header class="mb-6 space-y-4 print:mb-4">
  <div class="flex flex-wrap items-center gap-2">
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-slate-100 print:text-xl print:text-black">
      <%= @document.title %>
    </h1>

    <%= document_category_badge(@document.document_category) %>

    <% if @document.internal_only? %>
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                   bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-200">
        <%= t("views.documents.internal") %>
      </span>
    <% end %>

    <%= document_preview_text_badge(@document) %>
  </div>

  <% if @document.description.present? %>
    <p class="text-slate-600 dark:text-slate-400 max-w-3xl"><%= simple_format(@document.description) %></p>
  <% end %>

  <p class="text-sm text-slate-500 dark:text-slate-400 print:text-black">
    <%= t("views.documents.published_on") %>: <%= format_published_at(@document) %>
  </p>

  <div class="hidden print:block text-sm text-black space-y-1 border-t border-slate-300 pt-4">
    <p>
      <span class="font-semibold"><%= t("views.documents.print_category") %>:</span>
      <%= @document.document_category&.name %>
    </p>
    <p>
      <span class="font-semibold"><%= t("views.documents.print_url") %>:</span>
      <%= document_url(@document) %>
    </p>
  </div>

  <div class="flex flex-wrap gap-3 print:hidden">
    <% if current_user %>
      <%= render "bookmarks/button", document: @document %>
    <% end %>

    <%= link_to t("views.documents.open_in_new_tab"), preview_document_path(@document),
        target: "_blank", rel: "noopener",
        class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-md
                border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300
                bg-white dark:bg-slate-800 hover:bg-slate-50 dark:hover:bg-slate-700 shadow-sm",
        data: { turbo: false } %>

    <%= link_to t("views.documents.download"), download_document_path(@document),
        class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-md
                bg-indigo-600 dark:bg-indigo-500 text-white
                hover:bg-indigo-700 dark:hover:bg-indigo-600 shadow-sm",
        data: { turbo: false } %>

    <%= link_to t("views.shared.back"), documents_path,
        class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-md
                text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400" %>
  </div>

  <% if current_user&.admin? || current_user&.urednik? %>
    <div class="print:hidden mt-4">
      <details class="inline-block">
        <summary class="cursor-pointer text-sm font-medium text-slate-600 dark:text-slate-300
                        hover:text-indigo-600 dark:hover:text-indigo-400">
          <%= t("views.documents.show_qr") %>
        </summary>
        <div class="mt-3 inline-block rounded-lg border border-slate-200 dark:border-slate-700
                    bg-white p-3 shadow-sm">
          <%= qr_code_svg(document_url(@document), size: 160) %>
          <p class="mt-2 text-xs text-slate-500 text-center max-w-[160px]">
            <%= t("views.documents.qr_hint") %>
          </p>
        </div>
      </details>
    </div>
  <% end %>
</header>

<div class="md:hidden print:hidden mb-6">
  <%= link_to t("views.documents.open_document"), preview_document_path(@document),
      target: "_blank", rel: "noopener",
      class: "flex items-center justify-center w-full px-4 py-4 text-base font-medium rounded-lg
              bg-indigo-600 dark:bg-indigo-500 text-white
              hover:bg-indigo-700 dark:hover:bg-indigo-600 shadow-sm",
      data: { turbo: false } %>
  <p class="mt-2 text-sm text-slate-500 dark:text-slate-400 text-center">
    <%= t("views.documents.preview_mobile_hint") %>
  </p>
</div>

<div class="hidden md:block print:hidden" data-controller="document-preview">
  <iframe src="<%= preview_document_path(@document) %>"
          title="<%= @document.title %>"
          class="w-full h-[80vh] rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900"
          data-document-preview-target="iframe"
          data-action="load->document-preview#loaded"></iframe>

  <p class="mt-3 text-sm text-slate-500 dark:text-slate-400 hidden"
     data-document-preview-target="fallback"
     role="status">
    <%= t("views.documents.preview_fallback") %>
    <%= link_to t("views.documents.open_in_new_tab"), preview_document_path(@document),
        target: "_blank", rel: "noopener",
        class: "text-indigo-600 dark:text-indigo-400 hover:underline",
        data: { turbo: false } %>.
  </p>
</div>
