<% selected_category = @document_categories.find { |c| c.id == @selected_category_id.to_i } if @selected_category_id.present? %>
<% content_for :title, [t("views.titles.documents"), selected_category&.name].compact.join(" — ") %>

<h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 mb-6">
  <%= t("views.documents.title") %>
</h1>

<%= render "documents/list",
    document_categories: @document_categories,
    selected_category_id: @selected_category_id,
    documents: @documents,
    pagy: @pagy,
    filter_base: :documents %>
