<% content_for :title, t("views.titles.login") %>

<div class="min-h-screen flex items-start justify-center bg-slate-50 dark:bg-slate-900 pt-16 sm:pt-24">
  <div class="max-w-md w-full bg-white dark:bg-slate-800 rounded-lg shadow-lg p-8">
    <h1 class="text-2xl font-bold text-center text-slate-900 dark:text-slate-100 mb-2">
      Intranet — Prijava
    </h1>

    <p class="text-sm text-center text-slate-600 dark:text-slate-400 mb-6">
      Prijavni podatki so enaki kot za aplikacijo <strong>Prisotnost</strong>.
    </p>

    <% if flash[:alert] %>
      <div class="mb-4 p-3 bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300 rounded">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with url: login_path, method: :post, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :username, "Uporabniško ime",
            class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.text_field :username, autofocus: true, required: true,
            class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-700
                    dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= f.label :password, "Geslo",
            class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.password_field :password,
            class: "w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-700
                    dark:text-slate-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= f.submit "Prijava",
            class: "w-full py-2 px-4 bg-indigo-600 hover:bg-indigo-700
                    text-white font-medium rounded-md shadow
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500
                    dark:bg-indigo-500 dark:hover:bg-indigo-600 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
