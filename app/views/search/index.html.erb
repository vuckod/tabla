<% content_for :title, @query.present? ? t("views.titles.search_query", query: @query) : t("views.titles.search") %>

<h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 mb-6 print:text-xl print:text-black print:mb-4">
  <%= t("views.search.title") %>
</h1>

<div class="max-w-xl mb-8 print:hidden">
  <%= render "layouts/search_form" %>
</div>

<% if @query.blank? %>
  <p class="text-slate-500 dark:text-slate-400"><%= t("views.search.prompt") %></p>
<% elsif @documents.empty? %>
  <%= render "shared/empty_state",
      icon: :search,
      title: t("views.search.no_results_title", query: @query),
      message: t("views.search.no_results_hint"),
      action: link_to(t("views.search.clear_search"), search_path,
          class: "text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:underline") %>
<% else %>
  <% if @search_fallback %>
    <p class="text-sm text-amber-700 dark:text-amber-300 mb-4 p-3 rounded-md
              bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800"
       role="status">
      <%= t("views.search.fallback_notice") %>
    </p>
  <% end %>

  <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">
    <%= t("views.search.results_for", query: @query, count: @pagy.count) %>
  </p>

  <div class="space-y-3">
    <% @documents.each do |document| %>
      <%= render "search/result",
          document: document,
          highlight_html: search_highlight_snippet(@highlights_by_id[document.id]) %>
    <% end %>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-8 flex justify-center">
      <%= pagy_nav_tailwind(@pagy) %>
    </div>
  <% end %>
<% end %>
