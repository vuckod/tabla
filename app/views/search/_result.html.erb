<article class="flex flex-col sm:flex-row sm:items-center gap-4 p-4 rounded-lg border
                border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 shadow-sm
                hover:border-indigo-200 dark:hover:border-indigo-800 transition-colors">
  <div class="flex-1 min-w-0">
    <div class="flex flex-wrap items-center gap-2 mb-1">
      <h2 class="text-base font-semibold text-slate-900 dark:text-slate-100">
        <%= link_to document.title, document_path(document),
            class: "hover:text-indigo-600 dark:hover:text-indigo-400",
            data: { turbo_frame: "_top" } %>
      </h2>

      <%= document_category_badge(document.document_category) %>

      <% if document.internal_only? %>
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                     bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-200">
          <%= t("views.documents.internal") %>
        </span>
      <% end %>
    </div>

    <% if current_user %>
      <% if local_assigns[:highlight_html].present? %>
        <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-3">
          <%= sanitize(local_assigns[:highlight_html],
              tags: %w[mark],
              attributes: %w[class]) %>
        </p>
      <% elsif document.description.present? %>
        <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2"><%= document.description %></p>
      <% end %>
    <% else %>
      <%# Za neprijavljene: zameglena lorem ipsum placeholder + namig za prijavo.
          Pravega snippeta NE pošljemo — namesto njega je fiksen demo tekst, ki signalizira,
          da vsebina obstaja. Tehnično blur ni varovalka (HTML je dostopen), ampak ker je
          tekst fake, ni nobenega razkritja. %>
      <p aria-hidden="true"
         class="text-sm text-slate-600 dark:text-slate-400 line-clamp-3 blur-[3px]
                select-none pointer-events-none">
        <%= t("views.search.preview_lorem") %>
      </p>
      <p class="text-xs mt-2 flex items-center gap-1.5 text-slate-600 dark:text-slate-400">
        <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24"
             stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
        </svg>
        <span>
          <%= t("views.search.preview_login_prefix") %>
          <%= link_to t("views.search.preview_login_link"),
              login_path(return_to: search_path(q: @query)),
              class: "font-semibold text-indigo-600 dark:text-indigo-400 hover:underline" %>.
        </span>
      </p>
    <% end %>

    <p class="text-xs text-slate-500 dark:text-slate-400 mt-2">
      <%= t("views.documents.published_on") %>: <%= format_published_at(document) %>
    </p>
  </div>

  <div class="shrink-0 print:hidden">
    <%= link_to t("views.documents.download"), download_document_path(document),
        class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-md
                bg-indigo-600 dark:bg-indigo-500 text-white
                hover:bg-indigo-700 dark:hover:bg-indigo-600 shadow-sm",
        data: { turbo: false } %>
  </div>
</article>
