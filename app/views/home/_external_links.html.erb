<%= render layout: "shared/block",
    locals: { title: t("views.home.links_block"), color: :teal } do %>
  <% if external_link_categories.any? { |c| c.links.any? { |l| !l.internal_app? } } %>
    <div class="space-y-3">
      <% external_link_categories.each do |category| %>
        <% links = category.links.reject(&:internal_app?).sort_by { |l| [l.position, l.title] } %>
        <% next if links.empty? %>

        <div>
          <h3 class="text-xs font-bold uppercase tracking-wide text-teal-900/70 dark:text-teal-200/80 mb-1">
            <%= category.name %>
          </h3>
          <ul class="space-y-0.5">
            <% links.each do |link| %>
              <li><%= link_to_external_block(link) %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm opacity-80"><%= t("views.links.empty_category") %></p>
  <% end %>

  <p class="mt-4 pt-3 border-t border-teal-300/50 dark:border-teal-700/50">
    <%= link_to t("views.home.all_links"), links_path,
        class: "text-xs font-semibold text-slate-900 dark:text-slate-100 hover:text-teal-800 dark:hover:text-teal-300 underline-offset-2 hover:underline" %>
  </p>
<% end %>
