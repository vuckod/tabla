<%= render layout: "shared/block",
    locals: { title: t("views.home.apps_block"), color: :green } do %>
  <% if internal_links.any? %>
    <div class="space-y-2">
      <% internal_links.each do |link| %>
        <%= link_to_internal_block(link) %>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm opacity-80"><%= t("views.links.no_internal_apps") %></p>
  <% end %>
<% end %>
