<%= render layout: "shared/block",
    locals: { title: t("views.home.recent_documents"), color: :indigo } do %>
  <%= render "documents/list",
      document_categories: document_categories,
      selected_category_id: selected_category_id,
      documents: documents,
      pagy: pagy,
      filter_base: :home %>

  <p class="mt-4 pt-3 border-t border-indigo-300/50 dark:border-indigo-700/50">
    <%= link_to t("views.home.all_documents"), documents_path,
        class: "text-sm font-semibold text-slate-900 dark:text-slate-100 hover:text-indigo-800 dark:hover:text-indigo-300 underline-offset-2 hover:underline",
        data: { turbo_frame: "_top" } %>
  </p>
<% end %>
