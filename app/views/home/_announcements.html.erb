<%= render layout: "shared/block",
    locals: { title: t("views.home.urgent_announcements"), color: :red } do %>
  <div class="space-y-4">
    <% announcements.each do |announcement| %>
      <article class="rounded-lg border border-red-200/60 dark:border-red-800/60 bg-white/70 dark:bg-slate-900/40 p-4">
        <div class="flex flex-wrap items-center gap-2 mb-2">
          <% if announcement.pinned? %>
            <span class="shrink-0 text-base" title="<%= t("views.admin.announcements.pinned") %>" aria-label="<%= t("views.admin.announcements.pinned") %>">📌</span>
          <% end %>
          <h3 class="text-base font-semibold text-slate-900 dark:text-slate-100">
            <%= announcement.title %>
          </h3>
          <%= announcement_unit_badge(announcement.unit) %>
        </div>

        <p class="text-xs text-slate-600 dark:text-slate-400 mb-3">
          <%= t("views.documents.published_on") %>:
          <%= l(announcement.published_at, format: :short) %>
          <% if announcement.expires_at.present? %>
            · <%= t("views.home.announcement_expires") %>:
            <%= l(announcement.expires_at, format: :short) %>
          <% end %>
        </p>

        <% if announcement.body.present? %>
          <div class="text-sm text-slate-800 dark:text-slate-200">
            <%= simple_format(announcement.body) %>
          </div>
        <% end %>
      </article>
    <% end %>
  </div>
<% end %>
