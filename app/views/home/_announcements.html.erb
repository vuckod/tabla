<% if @announcements.any? %>
  <section aria-labelledby="home-announcements"
           class="mb-8 rounded-lg border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-900/20 p-5">
    <h2 id="home-announcements" class="text-lg font-semibold text-red-900 dark:text-red-100 mb-4">
      <%= t("views.home.urgent_announcements") %>
    </h2>

    <div class="space-y-4">
      <% @announcements.each do |announcement| %>
        <article class="rounded-md border border-red-100 dark:border-red-800/60 bg-white/80 dark:bg-slate-900/40 p-4">
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <h3 class="text-base font-semibold text-slate-900 dark:text-slate-100">
              <%= announcement.title %>
            </h3>
            <%= announcement_unit_badge(announcement.unit) %>
            <% if announcement.pinned? %>
              <span class="text-xs text-indigo-600 dark:text-indigo-400"><%= t("views.admin.announcements.pinned") %></span>
            <% end %>
          </div>

          <p class="text-xs text-slate-500 dark:text-slate-400 mb-3">
            <%= t("views.documents.published_on") %>:
            <%= l(announcement.published_at, format: :short) %>
            <% if announcement.expires_at.present? %>
              · <%= t("views.home.announcement_expires") %>:
              <%= l(announcement.expires_at, format: :short) %>
            <% end %>
          </p>

          <% if announcement.body.present? %>
            <div class="text-sm text-slate-700 dark:text-slate-300 prose prose-sm dark:prose-invert max-w-none">
              <%= simple_format(announcement.body) %>
            </div>
          <% end %>
        </article>
      <% end %>
    </div>
  </section>
<% end %>
